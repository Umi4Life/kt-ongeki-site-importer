{
  "name": "kt-ongeki-site-importer",
  "version": "1.0.0",
  "description": "Import scores from https://ongeki-net.com to Kamaitachi",
  "main": "index.js",
  "scripts": {
    "build": "node scripts/bundle.js",
    "generate:lookups": "node scripts/generate-tachi-lookups.js",
    "verify:lookups": "node scripts/generate-tachi-lookups.js && git diff --exit-code -- src/ongeki-importer/config/tachi-chart-lookups.ts",
    "prebuild": "npm run generate:lookups && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "watch": "node scripts/watch.js",
    "watch:remote": "node scripts/watch.js --remote",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Umi4Life/kt-ongeki-site-importer.git"
  },
  "keywords": [],
  "author": "Umi4Life",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "bugs": {
    "url": "https://github.com/Umi4Life/kt-ongeki-site-importer/issues"
  },
  "homepage": "https://github.com/Umi4Life/kt-ongeki-site-importer#readme",
  "dependencies": {
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "bundlemonkey": "^0.7.6",
    "esbuild": "^0.27.2",
    "eslint": "^9.39.2",
    "happy-dom": "^20.10.6",
    "vitest": "^4.1.10"
  }
}
